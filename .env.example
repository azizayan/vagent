# Freya — Interruptible Voice Agent
# Copy to `.env` and fill in. Real `.env` lives only on the deployment box; never commit it.

# ---- OpenAI (LLM) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Deepgram (STT) ----
DEEPGRAM_API_KEY=

# ---- Cartesia (TTS) ----
CARTESIA_API_KEY=
# Default Sonic voice id; overridable per-session via the config UI.
CARTESIA_DEFAULT_VOICE_ID=

# ---- Daily (WebRTC transport) ----
DAILY_API_KEY=
# Your Daily subdomain, e.g. "freya" if rooms live at https://freya.daily.co/<room>
DAILY_DOMAIN=

# ---- Backend runtime ----
# CORS allowlist for the deployed frontend origin. Comma-separated, no spaces.
# Local default below works for `docker compose up`; override on EC2 with the tunnel hostname.
BACKEND_CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# ---- Frontend ----
# Base URL the browser uses to reach the backend.
# Default `/api` keeps everything on the frontend origin (Next.js rewrites to the backend
# container internally), so only the frontend needs to be tunneled in production.
# Override to an absolute URL if you tunnel the backend on a separate hostname.
NEXT_PUBLIC_API_URL=/api
# Public Chapter 1 room URL printed by `python -m app.bot`, for example:
# https://your-domain.daily.co/freya-ch1
NEXT_PUBLIC_DAILY_ROOM_URL=
